{
  "_readme": {
    "파일용도": "나노바나나 템플릿 디자인 설계도 — 에이전시가 이 JSON 보고 나노바나나에 직접 레이어 구성",
    "캔버스": "800 x 1400px / 배경 #FFFFFF",
    "폰트": "나노바나나 Custom Fonts에 업로드된 NotoSansKR-Regular / NotoSansKR-Bold 사용",
    "섹션구성": ["SECTION 1: 제품 (사진 + 제품명 + 밀도 + 등급)", "SECTION 2: 특성 (비교이미지 + 도넛차트)", "SECTION 3: 용도 (아이콘 3개 + 라벨)"],
    "다음단계": "이 템플릿 완성 후 → ChatGPT API가 구글시트 데이터 채움 → Apps Script로 나노바나나 API 호출"
  },

  "canvas": {
    "width": 800,
    "height": 1400,
    "background_color": "#FFFFFF"
  },

  "sections": [

    {
      "id": "section_1",
      "name": "제품 (Product Hero)",
